---
import Head from '../components/Head.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  slug?: string;
  showSidebar?: boolean;
}

const { title, description, lang = 'ko', slug, showSidebar = true } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <Head title={title} description={description} lang={lang} slug={slug} />
</head>
<body>
  {showSidebar && <Sidebar lang={lang} currentSlug={slug} />}
  <main class:list={[{ 'with-sidebar': showSidebar }]}>
    <slot />
  </main>
</body>
</html>

<style is:global>
  :root {
    --accent: #a78bfa;
    --bg: #0f172a;
    --bg-sidebar: #0c0f1a;
    --text: #e2e8f0;
    --text-muted: #94a3b8;
    --border: rgba(255,255,255,0.1);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 15px;
    line-height: 1.7;
  }

  main.with-sidebar {
    margin-left: 260px;
    max-width: 800px;
    padding: 32px 40px;
  }

  /* Typography */
  h1 { font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 16px; border: none; }
  h2 { font-size: 1.3rem; font-weight: 700; color: #fff; margin-top: 32px; margin-bottom: 12px; }
  h3 { font-size: 1.1rem; font-weight: 600; color: #e2e8f0; margin-top: 24px; margin-bottom: 8px; }

  p { margin-bottom: 12px; }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 24px 0;
  }

  /* Code blocks */
  pre {
    background: #1e293b;
    border-radius: 8px;
    padding: 16px;
    overflow-x: auto;
    margin: 12px 0;
    font-size: 13px;
  }
  code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9em;
  }
  :not(pre) > code {
    background: rgba(167,139,250,0.1);
    padding: 2px 6px;
    border-radius: 4px;
    color: #c4b5fd;
  }

  /* Tables */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0;
    font-size: 14px;
  }
  th, td {
    padding: 8px 12px;
    border: 1px solid rgba(255,255,255,0.1);
    text-align: left;
    white-space: nowrap;
  }
  td:last-child {
    white-space: normal;
  }
  th { background: rgba(167,139,250,0.08); color: #fff; font-weight: 600; }
  tr:hover { background: rgba(255,255,255,0.02); }

  /* Lists */
  ul, ol { margin: 8px 0; padding-left: 24px; }
  li { margin: 4px 0; }

  /* Blockquotes */
  blockquote {
    border-left: 3px solid var(--accent);
    padding: 8px 16px;
    margin: 12px 0;
    color: var(--text-muted);
    background: rgba(167,139,250,0.04);
    border-radius: 0 8px 8px 0;
  }

  /* Bold */
  strong { color: #fff; }

  /* Mobile */
  @media (max-width: 768px) {
    main.with-sidebar {
      margin-left: 0;
      padding: 20px 16px;
    }
  }
</style>
