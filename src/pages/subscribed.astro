---
import Head from '../components/Head.astro';
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <Head title="Subscription Confirmed - Claude News" lang="ko" />
</head>
<body>
  <section class="cover">
    <div class="cover-main">
      <h1 id="heading">Subscription Confirmed!</h1>
      <p class="desc" id="message">Your subscription has been confirmed. We'll notify you when new briefings are published.</p>
      <a href="/" class="btn" id="btn">Go to Claude News</a>
    </div>
  </section>
  <script>
    const params = new URLSearchParams(window.location.search);
    const lang = params.get('lang');
    const h = document.getElementById('heading')!;
    const m = document.getElementById('message')!;
    const b = document.getElementById('btn')!;
    if (lang === 'ko') {
      h.textContent = '구독이 확인되었습니다!';
      m.textContent = '새 브리핑이 발행되면 이메일로 알려드리겠습니다.';
      b.textContent = 'Claude News로 이동';
    } else if (lang === 'ja') {
      h.textContent = '購読が確認されました！';
      m.textContent = '新しいブリーフィングが公開されたらメールでお知らせします。';
      b.textContent = 'Claude Newsへ移動';
    }
  </script>
</body>
</html>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
  .cover {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
    text-align: center;
    padding: 40px 20px;
  }
  .cover-main { max-width: 500px; }
  h1 {
    color: #fff;
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 24px;
  }
  .desc {
    color: #cbd5e1;
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 12px;
  }
  .btn {
    display: inline-block;
    color: #fff;
    background: #7c3aed;
    border-radius: 2rem;
    padding: 0.75rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    margin-top: 24px;
  }
  .btn:hover { background: #6d28d9; }
</style>
