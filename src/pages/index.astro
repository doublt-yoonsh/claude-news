---
import { getCollection } from 'astro:content';
import Head from '../components/Head.astro';

const posts = await getCollection('ko');
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latest = posts[0];

const enPosts = await getCollection('en');
enPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestEn = enPosts[0];

const jaPosts = await getCollection('ja');
jaPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestJa = jaPosts[0];
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <Head title="Claude Code Daily Briefing" lang="ko" />
</head>
<body>
  <section class="cover">
    <div class="cover-main">
      <h1>Claude Code Daily Briefing</h1>
      <blockquote>
        <p>AI 뉴스 브리핑 / AI News Briefing / AI ニュースブリーフィング</p>
      </blockquote>
      <ul>
        <li>Updated daily at 10:00 AM KST</li>
        <li>매일 오전 10시 자동 발행</li>
        <li>毎朝10時（KST）自動配信</li>
      </ul>
      <div class="buttons">
        <a href={`/briefings/${latest.id}/`}>한국어</a>
        {latestEn && <a href={`/en/briefings/${latestEn.id}/`}>English</a>}
        {latestJa && <a href={`/ja/briefings/${latestJa.id}/`}>日本語</a>}
      </div>
      <div class="subscribe-section">
        <form class="cover-subscribe" id="cover-subscribe-form">
          <input type="email" name="email" placeholder="이메일로 브리핑 받기" required />
          <select name="lang" class="lang-select">
            <option value="ko">한국어</option>
            <option value="en">English</option>
            <option value="ja">日本語</option>
          </select>
          <button type="submit">구독</button>
        </form>
        <p class="subscribe-note">새 브리핑이 발행되면 이메일로 알려드립니다</p>
        <p class="subscribe-msg" id="cover-subscribe-msg" aria-live="polite"></p>
      </div>
      <script>
        const form = document.getElementById('cover-subscribe-form') as HTMLFormElement;
        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = (form.querySelector('input[name="email"]') as HTMLInputElement).value.trim();
          const lang = (form.querySelector('select[name="lang"]') as HTMLSelectElement).value;
          const btn = form.querySelector('button') as HTMLButtonElement;
          const msg = document.getElementById('cover-subscribe-msg') as HTMLElement;
          if (!email) return;
          btn.disabled = true;
          btn.textContent = '처리 중...';
          msg.textContent = '';
          msg.className = 'subscribe-msg';
          try {
            const res = await fetch('https://emailoctopus.com/api/1.6/lists/4a18eb0e-18ac-11f1-8b8b-59033e1b4cf3/contacts', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                api_key: 'eo_6f7824c66015242db4a1215f6c9ca72190b1dea33aa42363c31158bbc1abdbe6',
                email_address: email,
                tags: [lang],
                status: 'PENDING',
              }),
            });
            if (res.ok) {
              msg.textContent = '인증 메일을 보내드렸습니다. 이메일을 확인해주세요!';
              msg.classList.add('success');
              (form.querySelector('input[name="email"]') as HTMLInputElement).value = '';
            } else {
              const data = await res.json();
              if (data.error?.code === 'MEMBER_EXISTS_WITH_EMAIL_ADDRESS') {
                msg.textContent = '이미 구독 중인 이메일입니다.';
              } else {
                msg.textContent = '오류가 발생했습니다. 다시 시도해주세요.';
              }
              msg.classList.add('error');
            }
          } catch {
            msg.textContent = '오류가 발생했습니다. 다시 시도해주세요.';
            msg.classList.add('error');
          } finally {
            btn.disabled = false;
            btn.textContent = '구독';
          }
        });
      </script>
    </div>
  </section>
</body>
</html>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }

  .cover {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
    text-align: center;
    padding: 40px 20px;
  }
  .cover-main { max-width: 600px; }
  h1 {
    color: #fff;
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  blockquote {
    border: none;
    margin: 0 0 20px;
  }
  blockquote p {
    color: #cbd5e1;
    font-size: 1.2rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
  }
  ul li {
    color: #94a3b8;
    font-size: 1rem;
    margin: 0.3rem 0;
  }
  .buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .buttons a {
    display: inline-block;
    color: #fff;
    background: #7c3aed;
    border: none;
    border-radius: 2rem;
    padding: 0.75rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }
  .buttons a:hover { background: #6d28d9; }

  .subscribe-section {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .cover-subscribe {
    display: flex;
    gap: 8px;
    max-width: 380px;
    margin: 0 auto;
  }
  .cover-subscribe input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: #e2e8f0;
    font-size: 0.875rem;
  }
  .cover-subscribe input::placeholder { color: #94a3b8; }
  .cover-subscribe input:focus { outline: none; border-color: #a78bfa; }
  .lang-select {
    padding: 10px 28px 10px 10px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: #e2e8f0;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .lang-select:focus { outline: none; border-color: #a78bfa; }
  .subscribe-msg {
    font-size: 0.8rem;
    margin-top: 8px;
    min-height: 1.2em;
  }
  .subscribe-msg.success { color: #4ade80; }
  .subscribe-msg.error { color: #f87171; }
  .cover-subscribe button {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    background: #7c3aed;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }
  .cover-subscribe button:hover { background: #6d28d9; }
  .subscribe-note {
    color: #64748b;
    font-size: 0.8rem;
    margin-top: 8px;
  }

  @media (max-width: 480px) {
    .cover-subscribe { flex-direction: column; }
  }
</style>
