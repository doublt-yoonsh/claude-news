---
import { getCollection } from 'astro:content';
import Head from '../components/Head.astro';

const posts = await getCollection('ko');
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latest = posts[0];

const enPosts = await getCollection('en');
enPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestEn = enPosts[0];

const jaPosts = await getCollection('ja');
jaPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latestJa = jaPosts[0];
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <Head title="Claude Code Daily Briefing" lang="ko" />
</head>
<body>
  <section class="cover">
    <div class="cover-main">
      <h1>Claude Code Daily Briefing</h1>
      <blockquote>
        <p>AI 뉴스 브리핑 / AI News Briefing / AI ニュースブリーフィング</p>
      </blockquote>
      <ul>
        <li>Updated daily at 10:00 AM KST</li>
        <li>매일 오전 10시 자동 발행</li>
        <li>毎朝10時（KST）自動配信</li>
      </ul>
      <div class="buttons">
        <a href={`/briefings/${latest.id}/`}>한국어</a>
        {latestEn && <a href={`/en/briefings/${latestEn.id}/`}>English</a>}
        {latestJa && <a href={`/ja/briefings/${latestJa.id}/`}>日本語</a>}
      </div>
      <div class="subscribe-section">
        <form
          action="https://buttondown.com/api/emails/embed-subscribe/YOUR_USERNAME"
          method="post"
          target="popupwindow"
          class="cover-subscribe"
        >
          <input type="email" name="email" placeholder="이메일로 브리핑 받기" required />
          <button type="submit">구독</button>
        </form>
        <p class="subscribe-note">새 브리핑이 발행되면 이메일로 알려드립니다</p>
      </div>
    </div>
  </section>
</body>
</html>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }

  .cover {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
    text-align: center;
    padding: 40px 20px;
  }
  .cover-main { max-width: 600px; }
  h1 {
    color: #fff;
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  blockquote {
    border: none;
    margin: 0 0 20px;
  }
  blockquote p {
    color: #cbd5e1;
    font-size: 1.2rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
  }
  ul li {
    color: #94a3b8;
    font-size: 1rem;
    margin: 0.3rem 0;
  }
  .buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .buttons a {
    display: inline-block;
    color: #fff;
    background: #7c3aed;
    border: none;
    border-radius: 2rem;
    padding: 0.75rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }
  .buttons a:hover { background: #6d28d9; }

  .subscribe-section {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .cover-subscribe {
    display: flex;
    gap: 8px;
    max-width: 380px;
    margin: 0 auto;
  }
  .cover-subscribe input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.08);
    color: #e2e8f0;
    font-size: 0.875rem;
  }
  .cover-subscribe input::placeholder { color: #94a3b8; }
  .cover-subscribe input:focus { outline: none; border-color: #a78bfa; }
  .cover-subscribe button {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    background: #7c3aed;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }
  .cover-subscribe button:hover { background: #6d28d9; }
  .subscribe-note {
    color: #64748b;
    font-size: 0.8rem;
    margin-top: 8px;
  }

  @media (max-width: 480px) {
    .cover-subscribe { flex-direction: column; }
  }
</style>
