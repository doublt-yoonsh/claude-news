---
import { getCollection } from 'astro:content';
import LangSwitcher from './LangSwitcher.astro';
import Search from './Search.astro';

interface Props {
  lang: string;
  currentSlug?: string;
}

const { lang, currentSlug } = Astro.props;

const collectionName = lang as 'ko' | 'en' | 'ja';
const posts = await getCollection(collectionName);
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Group by month
const grouped = new Map<string, typeof posts>();
for (const post of posts) {
  const d = new Date(post.data.date);
  const month = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  if (!grouped.has(month)) grouped.set(month, []);
  grouped.get(month)!.push(post);
}

const prefix = lang === 'ko' ? '' : `/${lang}`;


// Find which month contains the active post
const activeMonth = (() => {
  if (!currentSlug) return [...grouped.keys()][0] || '';
  for (const [month, items] of grouped) {
    if (items.some(p => p.id === currentSlug)) return month;
  }
  return [...grouped.keys()][0] || '';
})();
---

<aside class="sidebar">
  <div class="sidebar-header">
    <a href={prefix || '/'} class="site-title">Claude Code Daily Briefing</a>
    <button class="nav-toggle" aria-label="Toggle date list" aria-expanded="false">
      <span class="toggle-icon">▼</span> Dates
    </button>
  </div>
  <div class="sidebar-collapsible collapsed">
    <LangSwitcher currentLang={lang} slug={currentSlug} />
    <Search />
    <nav class="sidebar-nav">
      {[...grouped.entries()].map(([month, items]) => {
        const isActiveMonth = month === activeMonth;
        return (
          <div class:list={['month-group', { open: isActiveMonth }]}>
            <button class="month-label" aria-expanded={isActiveMonth ? 'true' : 'false'}>
              <span class="month-arrow">{isActiveMonth ? '▾' : '▸'}</span>
              {month}
            </button>
            <ul class="month-list" style={isActiveMonth ? '' : 'display:none'}>
              {items.map(post => {
                const d = new Date(post.data.date);
                const shortDate = `${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
                const href = `${prefix}/briefings/${post.id}/`;
                const isActive = post.id === currentSlug;
                return (
                  <li>
                    <a href={href} class:list={[{ active: isActive }]}>{shortDate}</a>
                  </li>
                );
              })}
            </ul>
          </div>
        );
      })}
    </nav>
  </div>
</aside>

<script>
  // Mobile nav toggle
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const collapsible = document.querySelector('.sidebar-collapsible') as HTMLElement;
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    collapsible.classList.toggle('collapsed');
    const icon = toggle.querySelector('.toggle-icon');
    if (icon) icon.textContent = expanded ? '▼' : '▲';
  });

  // Month group accordion
  document.querySelectorAll('.month-label').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.parentElement!;
      const list = group.querySelector('.month-list') as HTMLElement;
      const arrow = btn.querySelector('.month-arrow') as HTMLElement;
      const isOpen = group.classList.contains('open');
      group.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(!isOpen));
      if (list) list.style.display = isOpen ? 'none' : '';
      if (arrow) arrow.textContent = isOpen ? '▸' : '▾';
    });
  });
</script>

<style>
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: 260px;
    background: #0c0f1a;
    border-right: 1px solid rgba(255,255,255,0.06);
    overflow-y: auto;
    padding: 16px;
    z-index: 100;
  }
  .sidebar-header {
    padding: 8px 0 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .site-title {
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
  }
  .nav-toggle {
    display: none;
    align-items: center;
    gap: 4px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: #94a3b8;
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 6px;
    cursor: pointer;
  }
  .nav-toggle:hover { background: rgba(255,255,255,0.12); color: #fff; }
  .toggle-icon { font-size: 10px; }
  .month-label {
    display: flex;
    align-items: center;
    gap: 4px;
    width: 100%;
    background: none;
    border: none;
    color: #94a3b8;
    font-size: 13px;
    font-weight: 700;
    margin: 12px 0 4px;
    padding: 2px 0;
    cursor: pointer;
    text-align: left;
  }
  .month-label:hover { color: #cbd5e1; }
  .month-arrow { font-size: 11px; width: 12px; }
  ul { list-style: none; padding: 0; margin: 0; }
  li a {
    display: block;
    color: #cbd5e1;
    font-size: 14px;
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 4px;
  }
  li a:hover { background: rgba(167,139,250,0.1); color: #fff; }
  li a.active { background: rgba(167,139,250,0.2); color: #a78bfa; font-weight: 600; }

  @media (max-width: 768px) {
    .sidebar {
      position: relative;
      width: 100%;
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .nav-toggle { display: flex; }
    .sidebar-collapsible.collapsed { display: none; }
  }
</style>
