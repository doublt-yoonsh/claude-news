---
interface Props {
  title: string;
  description?: string;
  lang?: string;
  slug?: string;
  pubDate?: Date;
  isArticle?: boolean;
}

const { title, description, lang = 'ko', slug, pubDate, isArticle = false } = Astro.props;

const langMeta: Record<string, { locale: string; desc: string }> = {
  ko: { locale: 'ko_KR', desc: 'Claude Code, Anthropic 최신 뉴스를 매일 한국어로 전달합니다.' },
  en: { locale: 'en_US', desc: 'Daily AI news covering Claude Code updates, Anthropic releases, and developer ecosystem.' },
  ja: { locale: 'ja_JP', desc: 'Claude Code、Anthropicの最新ニュースを毎日日本語でお届けします。' },
};

const meta = langMeta[lang] || langMeta.ko;
const finalDescription = description || meta.desc;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const hreflangs = slug ? [
  { lang: 'ko', href: `${Astro.site}briefings/${slug}/` },
  { lang: 'en', href: `${Astro.site}en/briefings/${slug}/` },
  { lang: 'ja', href: `${Astro.site}ja/briefings/${slug}/` },
] : [
  { lang: 'ko', href: `${Astro.site}` },
  { lang: 'en', href: `${Astro.site}en/` },
  { lang: 'ja', href: `${Astro.site}ja/` },
];

const ogType = isArticle ? 'article' : 'website';

const jsonLd = isArticle && pubDate ? {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description: finalDescription,
  datePublished: pubDate.toISOString(),
  dateModified: pubDate.toISOString(),
  inLanguage: meta.locale.replace('_', '-'),
  url: canonicalURL.toString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
  publisher: {
    '@type': 'Organization',
    name: 'Claude Code Daily Briefing',
    url: Astro.site?.toString(),
  },
  author: {
    '@type': 'Organization',
    name: 'Claude Code Daily Briefing',
    url: Astro.site?.toString(),
  },
} : null;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={finalDescription} />
<link rel="canonical" href={canonicalURL} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate" type="application/rss+xml" title="Claude Code Daily Briefing" href="/rss.xml" />

<!-- hreflang -->
{hreflangs.map(h => (
  <link rel="alternate" hreflang={h.lang} href={h.href} />
))}
<link rel="alternate" hreflang="x-default" href={Astro.site} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Claude Code Daily Briefing" />
<meta property="og:title" content={title} />
<meta property="og:description" content={finalDescription} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:locale" content={meta.locale} />
{isArticle && pubDate && (
  <meta property="article:published_time" content={pubDate.toISOString()} />
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={finalDescription} />

{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-080SMBJEHN"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-080SMBJEHN');
</script>
