---
interface Props {
  lang?: string;
  compact?: boolean;
}

const { lang = 'ko', compact = false } = Astro.props;

const labels = {
  ko: {
    heading: '이메일로 브리핑 받기',
    desc: '새 브리핑이 발행되면 이메일로 알려드립니다.',
    placeholder: '이메일 주소',
    button: '구독하기',
    sending: '처리 중...',
    success: '인증 메일을 보내드렸습니다. 이메일을 확인해주세요!',
    error: '구독 처리 중 오류가 발생했습니다. 다시 시도해주세요.',
    duplicate: '이미 구독 중인 이메일입니다.',
  },
  en: {
    heading: 'Get briefings by email',
    desc: 'We\'ll notify you when new briefings are published.',
    placeholder: 'Email address',
    button: 'Subscribe',
    sending: 'Processing...',
    success: 'We sent you a confirmation email. Please check your inbox!',
    error: 'Something went wrong. Please try again.',
    duplicate: 'This email is already subscribed.',
  },
  ja: {
    heading: 'メールでブリーフィングを受け取る',
    desc: '新しいブリーフィングが公開されたらメールでお知らせします。',
    placeholder: 'メールアドレス',
    button: '購読する',
    sending: '処理中...',
    success: '確認メールを送信しました。メールをご確認ください！',
    error: 'エラーが発生しました。もう一度お試しください。',
    duplicate: 'このメールアドレスは既に登録されています。',
  },
};

const t = labels[lang as keyof typeof labels] || labels.ko;

const privacyLinks = {
  ko: { url: '/privacy/', text: '구독 시 <a href="/privacy/">개인정보 처리방침</a>에 동의합니다.' },
  en: { url: '/en/privacy/', text: 'By subscribing, you agree to our <a href="/en/privacy/">Privacy Policy</a>.' },
  ja: { url: '/ja/privacy/', text: '購読することで<a href="/ja/privacy/">プライバシーポリシー</a>に同意します。' },
};
const privacy = privacyLinks[lang as keyof typeof privacyLinks] || privacyLinks.ko;

---

<div class:list={['subscribe', { compact }]} data-lang={lang}>
  {!compact && <h3 class="subscribe-heading">{t.heading}</h3>}
  <p class="subscribe-desc">{t.desc}</p>
  <form class="subscribe-form" data-labels={JSON.stringify(t)}>
    <input type="email" name="email" placeholder={t.placeholder} required />
    <button type="submit">{t.button}</button>
  </form>
  <p class="subscribe-msg" aria-live="polite"></p>
  <p class="privacy-link" set:html={privacy.text} />
</div>

<script>
  document.querySelectorAll('.subscribe-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.currentTarget as HTMLFormElement;
      const container = formEl.closest('.subscribe') as HTMLElement;
      const labels = JSON.parse(formEl.dataset.labels || '{}');
      const msgEl = container.querySelector('.subscribe-msg') as HTMLElement;
      const btn = formEl.querySelector('button') as HTMLButtonElement;
      const input = formEl.querySelector('input') as HTMLInputElement;
      const email = input.value.trim();

      if (!email) return;

      const lang = container.dataset.lang;

      btn.disabled = true;
      btn.textContent = labels.sending;
      msgEl.textContent = '';
      msgEl.className = 'subscribe-msg';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, lang }),
        });

        if (res.ok) {
          msgEl.textContent = labels.success;
          msgEl.classList.add('success');
          input.value = '';
        } else {
          const data = await res.json();
          if (data.error?.code === 'MEMBER_EXISTS_WITH_EMAIL_ADDRESS') {
            msgEl.textContent = labels.duplicate;
            msgEl.classList.add('error');
          } else {
            msgEl.textContent = labels.error;
            msgEl.classList.add('error');
          }
        }
      } catch {
        msgEl.textContent = labels.error;
        msgEl.classList.add('error');
      } finally {
        btn.disabled = false;
        btn.textContent = labels.button;
      }
    });
  });
</script>

<style>
  .subscribe {
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: 12px;
    padding: 24px;
    margin: 32px 0;
    background: rgba(167, 139, 250, 0.05);
    text-align: center;
  }
  .subscribe.compact {
    padding: 16px;
    margin: 16px 0;
  }
  .subscribe-heading {
    color: #e2e8f0;
    font-size: 1.1rem;
    margin: 0 0 8px;
  }
  .subscribe-desc {
    color: #94a3b8;
    font-size: 0.875rem;
    margin: 0 0 16px;
  }
  .compact .subscribe-desc {
    margin-bottom: 12px;
  }
  .subscribe-form {
    display: flex;
    gap: 8px;
    max-width: 400px;
    margin: 0 auto;
  }
  .subscribe-form input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    background: #1e293b;
    color: #e2e8f0;
    font-size: 0.875rem;
  }
  .subscribe-form input::placeholder {
    color: #64748b;
  }
  .subscribe-form input:focus {
    outline: none;
    border-color: #a78bfa;
  }
  .subscribe-form button {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    background: #7c3aed;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }
  .subscribe-form button:hover {
    background: #6d28d9;
  }
  .subscribe-form button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .subscribe-msg {
    font-size: 0.8rem;
    margin-top: 10px;
    min-height: 1.2em;
  }
  .subscribe-msg.success {
    color: #4ade80;
  }
  .subscribe-msg.error {
    color: #f87171;
  }
  .privacy-link {
    font-size: 0.75rem;
    color: #64748b;
    margin-top: 8px;
  }
  .privacy-link a {
    color: #94a3b8;
    text-decoration: underline;
  }
  .privacy-link a:hover {
    color: #a78bfa;
  }

  @media (max-width: 480px) {
    .subscribe-form {
      flex-direction: column;
    }
  }
</style>
